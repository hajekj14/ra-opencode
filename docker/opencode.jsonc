{
  "share": "disabled",
  "enabled_providers": ["azure-foundry"],
  "model": "azure-foundry/Kimi-K2.5",
  "small_model": "azure-foundry/Kimi-K2.5",
  "provider": {
    "azure-foundry": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure AI Foundry",
      "options": {
        "baseURL": "https://jiri-mnrwd2rg-eastus2.services.ai.azure.com/openai/v1/",
        "apiKey": "{env:AZURE_FOUNDRY_API_KEY}"
      },
      "models": {
        "Kimi-K2.5": {
          "name": "Kimi-K2.5",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "pwd": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rm *": "deny",
      "shutdown *": "deny",
      "reboot *": "deny"
    }
  }
}