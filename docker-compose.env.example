# Custom Debian/glibc image built from docker/Dockerfile (required for PTY/terminal support).
# Set OPENCODE_VERSION to pin to a specific release tag, e.g. v1.14.18
# OPENCODE_VERSION=v1.14.18
# Set OPENCODE_IMAGE to override the built image name/tag.
# OPENCODE_IMAGE=opencode-glibc:latest

# Default tenant: hajekj14
OPENCODE_BIND_ADDRESS_HAJEKJ14=127.0.0.1
OPENCODE_HOST_PORT_HAJEKJ14=4096
OPENCODE_SERVER_USERNAME_HAJEKJ14=hajekj14
OPENCODE_SERVER_PASSWORD_HAJEKJ14=change-me
OPENCODE_MAX_CPUS_HAJEKJ14=2.0
OPENCODE_MAX_MEMORY_HAJEKJ14=4g
OPENCODE_MAX_PIDS_HAJEKJ14=512

# Copy the hajekj14 variables with a new suffix for each extra tenant.
# Example:
# OPENCODE_BIND_ADDRESS_ANOTHER_USER=127.0.0.1
# OPENCODE_HOST_PORT_ANOTHER_USER=4097
# OPENCODE_SERVER_USERNAME_ANOTHER_USER=another-user
# OPENCODE_SERVER_PASSWORD_ANOTHER_USER=change-me
# OPENCODE_MAX_CPUS_ANOTHER_USER=2.0
# OPENCODE_MAX_MEMORY_ANOTHER_USER=4g
# OPENCODE_MAX_PIDS_ANOTHER_USER=512